{
  "apiType": "stageMode",
  "buildOption": {
    "externalNativeOptions": {
      "path": "../../CMakeLists.txt",
      "arguments": "-DOHOS=TRUE -DOHOS_STL=c++_shared -DUSE_FFMPEG=ON -DUSE_SDL3=OFF",
      "abiFilters": ["arm64-v8a", "x86_64"],
      "cppFlags": "--std=c++17"
    }
  },
  "targets": [
    {
      "name": "default",
      "runtimeOS": "HarmonyOS"
    }
  ]
}
