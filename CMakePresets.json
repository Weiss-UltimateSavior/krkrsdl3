{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "Windows Config",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "WINDOWS": true,
                "MINGW": true,
                "CMAKE_SYSTEM_NAME": "Windows",
                "CMAKE_MAKE_PROGRAM": "ninja",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/out/windows"
        },
        {
            "name": "Windows Config MSVC",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "WINDOWS": true,
                "MSVC": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/out/windows-msvc",
            "vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"hostOS": ["Windows"]
				}
			}
        },
        {
            "name": "Windows Config 32",
            "generator": "Visual Studio 17 2022",
            "architecture": "Win32",
            "cacheVariables": {
                "WINDOWS": true,
                "MSVC": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/out/windows-32",
            "vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"hostOS": ["Windows"]
				}
			}
        },
		{
            "name": "Windows Config Console",
            "generator": "Visual Studio 17 2022",
            "cacheVariables": {
                "WINDOWS": true,
                "MSVC": true,
				"ONLYCONSOLE": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "binaryDir": "${sourceDir}/out/windows-console",
            "vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"hostOS": ["Windows"]
				}
			}
        },
		{
            "name": "Linux Config",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "LINUX": true,
                "CMAKE_MAKE_PROGRAM": "ninja",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "binaryDir": "${sourceDir}/out/linux"
        },
		{
            "name": "Linux Config Console",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "LINUX": true,
				"ONLYCONSOLE": true,
                "CMAKE_MAKE_PROGRAM": "ninja",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "binaryDir": "${sourceDir}/out/linux-console"
        },
		{
            "name": "Emscripten Config",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME" : "Emscripten",
                "CMAKE_SYSTEM_VERSION" : "1",
                "CMAKE_C_COMPILER": "emcc.bat",
                "CMAKE_CXX_COMPILER": "em++.bat",
                "EMSCRIPTEN": true,
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_TOOLCHAIN_FILE": "$ENV{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            },
            "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
            "binaryDir": "${sourceDir}/out/emscripten"
        }
    ],
    "buildPresets": [
        {
            "name": "Windows Debug Build",
            "configurePreset": "Windows Config",
            "configuration": "Debug"
        },
        {
            "name": "Windows Release Build",
            "configurePreset": "Windows Config",
            "configuration": "Release"
        },
        {
            "name": "Windows Debug Build MSVC",
            "configurePreset": "Windows Config MSVC",
            "configuration": "Debug"
        },
        {
            "name": "Windows Release Build MSVC",
            "configurePreset": "Windows Config MSVC",
            "configuration": "Release"
        },
        {
            "name": "Windows Debug Build 32",
            "configurePreset": "Windows Config 32",
            "configuration": "Debug"
        },
        {
            "name": "Windows Release Build 32",
            "configurePreset": "Windows Config 32",
            "configuration": "Release"
        },
		{
            "name": "Windows Debug Build Console",
            "configurePreset": "Windows Config Console",
            "configuration": "Debug"
        },
        {
            "name": "Windows Release Build Console",
            "configurePreset": "Windows Config Console",
            "configuration": "Release"
        },
        {
            "name": "Linux Debug Build",
            "configurePreset": "Linux Config",
            "configuration": "Debug"
        },
        {
            "name": "Linux Release Build",
            "configurePreset": "Linux Config",
            "configuration": "Release"
        },
        {
            "name": "Linux Debug Build Console",
            "configurePreset": "Linux Config Console",
            "configuration": "Debug"
        },
        {
            "name": "Linux Release Build Console",
            "configurePreset": "Linux Config Console",
            "configuration": "Release"
        },
        {
            "name": "Emscripten Debug Build",
            "configurePreset": "Emscripten Config",
            "configuration": "Debug"
        },
        {
            "name": "Emscripten Release Build",
            "configurePreset": "Emscripten Config",
            "configuration": "Release"
        }
    ]
}